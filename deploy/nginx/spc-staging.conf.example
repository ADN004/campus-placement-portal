# ============================================================
# Host nginx vhost — STAGING (with basic-auth gate)
# ============================================================
# Install as: /etc/nginx/sites-available/<your-staging-domain>
#
# 1. Create the gate password file first:
#      sudo apt-get install -y apache2-utils
#      sudo htpasswd -c /etc/nginx/.htpasswd_spc_staging <gate-username>
#
# 2. Enable the site:
#      sudo ln -s /etc/nginx/sites-available/<your-staging-domain> /etc/nginx/sites-enabled/
#      sudo nginx -t && sudo systemctl reload nginx
#
# 3. Add TLS (certbot rewrites this file in place and adds the
#    HTTP→HTTPS redirect; all blocks below survive):
#      sudo certbot --nginx -d <your-staging-domain>
#
# Replace before use:
#   YOUR_STAGING_DOMAIN   e.g. staging.spc.gptcpalakkad.ac.in
#   FRONTEND_PORT         must match FRONTEND_PORT in .env.staging (e.g. 8082)
#   BACKEND_PORT          must match BACKEND_PORT in .env.staging  (e.g. 5003)
#
# Security layers provided here:
#   - basic-auth gate on the entire UI (before any page loads)
#   - /api/ exempt from basic auth (the app's JWT uses the Authorization
#     header; the two auth schemes cannot coexist on one request) — API
#     remains protected by the application's own JWT login
#   - X-Robots-Tag keeps staging out of search engines
# ============================================================

server {
    listen 80;
    server_name YOUR_STAGING_DOMAIN;

    # staging must never appear in search engines
    add_header X-Robots-Tag "noindex, nofollow" always;

    client_max_body_size 10M;

    location = /favicon.ico {
        access_log off;
        log_not_found off;
    }

    # API — protected by the app's own JWT login; basic auth must be OFF
    location /api/ {
        auth_basic off;
        proxy_pass http://127.0.0.1:BACKEND_PORT/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Entire UI behind the staging password gate
    location / {
        auth_basic "Staging Environment";
        auth_basic_user_file /etc/nginx/.htpasswd_spc_staging;
        proxy_pass http://127.0.0.1:FRONTEND_PORT;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
