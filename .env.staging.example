# ============================================
# STAGING ENVIRONMENT VARIABLES
# ============================================
# Copy to .env.staging on the server (same directory as the Makefile):
#   cp .env.staging.example .env.staging
#
# Staging runs from docker-compose.hub.yml as a separate compose project.
# All staging commands are 'make staging-*' — see docs/STAGING.md
#
# NEVER commit .env.staging (it is git-ignored).

# ============================================
# ENVIRONMENT IDENTITY (REQUIRED — safety guards depend on these)
# ============================================
# APP_ENV=staging forces email safe mode (emails are logged, never delivered)
# and is verified by 'make staging-guard' before destructive commands.
APP_ENV=staging

# Container name prefix. Must contain 'staging' and must not be 'spc'
# (production uses spc_postgres / spc_backend / spc_frontend).
CONTAINER_PREFIX=spc-staging

# ============================================
# IMAGES
# ============================================
DOCKERHUB_USERNAME=your_dockerhub_username

# Immutable image tag to run. Updated automatically by:
#   make staging-deploy TAG=staging-<sha>
# Tags are printed in the GitHub Actions job summary for the develop branch.
IMAGE_TAG=staging-0000000

# ============================================
# PORTS (must differ from production: 8081 frontend / 5002 backend)
# ============================================
FRONTEND_PORT=8082
BACKEND_PORT=5003

# ============================================
# RESOURCE LIMITS (staging runs leaner than production)
# ============================================
POSTGRES_MEM_LIMIT=256M
BACKEND_MEM_LIMIT=256M
POSTGRES_CPU_LIMIT=0.5
BACKEND_CPU_LIMIT=0.5

# ============================================
# DATABASE (isolated staging volume — never shared with production)
# ============================================
DB_NAME=campus_placement_portal
DB_USER=postgres
DB_PASSWORD=choose_a_staging_db_password

# ============================================
# JWT (use a DIFFERENT secret than production)
# ============================================
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_separate_staging_secret_minimum_64_characters
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ============================================
# FRONTEND / DOMAIN
# ============================================
# Staging subdomain (used for CORS and links inside captured emails)
FRONTEND_URL=https://staging.your-domain.example

# ============================================
# EMAIL (safe mode)
# ============================================
# With APP_ENV=staging, emails are ALWAYS captured to the backend logs and
# never delivered, regardless of any credentials below. View them with:
#   make staging-logs
# Leave EMAIL_MODE=log (explicit) and credentials empty.
EMAIL_MODE=log
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# ============================================
# CLOUDINARY (SEPARATE staging account — never production's)
# ============================================
# Create a free secondary Cloudinary account for staging. This keeps staging
# uploads/deletions physically isolated from production assets, even after a
# production data refresh.
CLOUDINARY_CLOUD_NAME=your_staging_cloud_name
CLOUDINARY_API_KEY=your_staging_api_key
CLOUDINARY_API_SECRET=your_staging_api_secret

# ============================================
# STAGING ADMINISTRATOR (dedicated staging account)
# ============================================
# Used by the base seeder (CREATE_SUPER_ADMIN=true) AND by the post-refresh
# sanitizer, which creates/resets this account after every production clone.
# Always log into staging admin with THIS account, never a production one.
SETUP_SECRET_KEY=any-staging-setup-key
CREATE_SUPER_ADMIN=true
SUPER_ADMIN_EMAIL=admin@staging.invalid
SUPER_ADMIN_PASSWORD=choose_a_staging_admin_password

# ============================================
# CREDENTIAL SANITIZATION (after prod refresh)
# ============================================
# staging-refresh-from-prod automatically resets EVERY non-super-admin
# password to this value, so production credentials never work on staging
# and testers can log in as any account.
STAGING_SANITIZE_PASSWORD=Staging@123

# ============================================
# MODE SWITCH (testing tool)
# ============================================
# Lets the staging super admin flip the portal between multi- and
# single-college mode from the Manage Colleges page (reversible — colleges
# are soft-deactivated with a snapshot, restore re-activates exactly them).
# NEVER set this in production .env: without it the feature is invisible
# and the endpoints refuse to run.
ENABLE_MODE_SWITCH=true

# ============================================
# MISC
# ============================================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
